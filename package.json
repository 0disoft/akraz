{
  "name": "akraz-workspace",
  "version": "0.1.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --cwd apps/akraz build",
    "check": "bun run format:check && bun run lint && bun run --cwd apps/akraz check && bun run build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix . --no-error-on-unmatched-pattern",
    "test": "bun test"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
